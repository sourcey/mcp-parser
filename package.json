{
  "name": "mcp-parser",
  "version": "0.2.0",
  "description": "Parse, validate, and snapshot Model Context Protocol servers.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mcp-parser": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "parser",
    "validator",
    "snapshot",
    "introspection",
    "ai",
    "llm",
    "agent",
    "tools",
    "documentation",
    "swagger-parser",
    "openapi"
  ],
  "author": "Kam Low <oss@0state.com> (https://sourcey.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sourcey/mcp-parser.git"
  },
  "bugs": {
    "url": "https://github.com/sourcey/mcp-parser/issues"
  },
  "homepage": "https://github.com/sourcey/mcp-parser",
  "dependencies": {
    "mcp-schema": "^0.2.0"
  }
}
